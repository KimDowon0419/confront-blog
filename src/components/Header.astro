---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const { pathname } = Astro.url;
// Match both '/blog' and '/blog/...' but not '/' for the active state of "Posts"
const isPostsActive = pathname.startsWith('/blog') || pathname === '/blog';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="right-section">
			<div class="internal-links">
				<HeaderLink href="/blog" class={isPostsActive ? "active" : ""}>Posts</HeaderLink>
				<HeaderLink href="/tags">Tags</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			
			<!-- Icons Section -->
			<div class="icon-links">
				<a href="/archives" aria-label="Archive">
					<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 8v13H3V8"></path>
						<path d="M1 3h22v5H1z"></path>
						<path d="M10 12h4"></path>
					</svg>
				</a>
				<a href="/search" aria-label="Search">
					<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="11" cy="11" r="8"></circle>
						<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
					</svg>
				</a>
				<button id="theme-toggle" aria-label="Toggle Dark Mode">
					<!-- Default to Moon (for light mode) -->
					<svg id="moon-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
					</svg>
					<!-- Sun (for dark mode) hidden by default -->
					<svg id="sun-icon" style="display: none;" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="5"></circle>
						<line x1="12" y1="1" x2="12" y2="3"></line>
						<line x1="12" y1="21" x2="12" y2="23"></line>
						<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
						<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
						<line x1="1" y1="12" x2="3" y2="12"></line>
						<line x1="21" y1="12" x2="23" y2="12"></line>
						<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
						<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
					</svg>
				</button>
			</div>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 2rem 0;
		background: transparent;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		max-width: 768px;
		margin: 0 auto;
		padding: 0 1.5rem;
		box-sizing: border-box;
	}
	h2 {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 700;
	}
	h2 a {
		text-decoration: none;
		color: var(--text-primary);
	}
	.right-section {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}
	.internal-links {
		display: flex;
		gap: 1.5rem;
	}
	.internal-links a {
		color: var(--text-primary);
		text-decoration: none;
		font-size: 1rem;
		font-weight: 500;
		padding: 0.25rem 0;
	}
	.internal-links a:hover {
		color: var(--accent-color);
	}
	/* Req 6: Active state wavy/dashed line */
	.internal-links a.active {
		color: var(--text-primary);
		text-decoration: underline;
		text-decoration-style: wavy;
		text-underline-offset: 6px;
	}

	.icon-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.icon-links a, #theme-toggle {
		background: none;
		border: none;
		color: var(--text-primary);
		cursor: pointer;
		display: flex;
		align-items: center;
		padding: 0.25rem;
		transition: color 0.2s ease;
	}
	.icon-links a:hover, #theme-toggle:hover {
		color: var(--accent-color);
	}
</style>

<script>
	const themeToggle = document.getElementById('theme-toggle');
	const moonIcon = document.getElementById('moon-icon');
	const sunIcon = document.getElementById('sun-icon');

	const currentTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

	if (currentTheme === 'dark') {
		document.documentElement.setAttribute('data-theme', 'dark');
		if(moonIcon && sunIcon) {
			moonIcon.style.display = 'none';
			sunIcon.style.display = 'block';
		}
	}

	themeToggle?.addEventListener('click', () => {
		const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
		if (isDark) {
			document.documentElement.removeAttribute('data-theme');
			localStorage.setItem('theme', 'light');
			if(moonIcon && sunIcon) {
				moonIcon.style.display = 'block';
				sunIcon.style.display = 'none';
			}
		} else {
			document.documentElement.setAttribute('data-theme', 'dark');
			localStorage.setItem('theme', 'dark');
			if(moonIcon && sunIcon) {
				moonIcon.style.display = 'none';
				sunIcon.style.display = 'block';
			}
		}
	});
</script>
