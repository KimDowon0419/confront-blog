---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<h1>confront</h1>
				<p>
					Welcome to the confront blog. Currently building and learning in public.
				</p>
				<div class="hero-social-links">
					<span>Social Links:</span>
					<!-- Placeholders for SNS as requested -->
					<a href="#" target="_blank" aria-label="GitHub">
						<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="css-i6dzq1"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
					</a>
					<a href="#" target="_blank" aria-label="Email">
						<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="css-i6dzq1"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
					</a>
				</div>
			</section>

			<hr />

			<section class="recent-posts">
				<h2>Recent Posts</h2>
				<ul>
					{
						posts.map((post) => (
							<li class="post-list-item">
								<a href={`/blog/${post.id}/`} class="post-title">
									{post.data.title}
								</a>
								<div class="post-date">
									<svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
										<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
										<line x1="16" y1="2" x2="16" y2="6"></line>
										<line x1="8" y1="2" x2="8" y2="6"></line>
										<line x1="3" y1="10" x2="21" y2="10"></line>
									</svg>
									<FormattedDate date={post.data.pubDate} />
								</div>
								<p>{post.data.description}</p>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-section {
		margin-bottom: 2rem;
	}
	.hero-section p {
		font-size: 1.125rem;
		margin-bottom: 1.5rem;
	}
	.hero-social-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1rem;
		color: var(--text-primary);
	}
	.hero-social-links a {
		color: var(--text-primary);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: transform 0.2s ease-in-out, color 0.2s ease;
	}
	.hero-social-links a:hover {
		transform: rotate(6deg) scale(1.1);
		color: var(--accent-color);
	}
	ol, ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.recent-posts h2 {
		margin-bottom: 1.5rem;
	}
</style>
