---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Search | ${SITE_TITLE}`} description="Search blog posts" />
	</head>
	<body>
		<Header />
		<main>
			<div class="breadcrumb">
				<a href="/">Home</a> » Search
			</div>
			
			<div class="page-title-section">
				<h1>Search</h1>
				<div class="search-container">
					<input type="text" id="search-input" placeholder="Search articles..." autofocus />
				</div>
			</div>

			<section class="recent-posts" id="search-results">
				<ul id="results-list">
					<!-- Results populated by JS -->
				</ul>
				<p id="no-results" style="display: none; color: var(--text-secondary);">No posts found.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.breadcrumb {
		font-size: 0.875rem;
		color: var(--text-secondary);
		margin-bottom: 0.5rem;
	}
	.breadcrumb a {
		text-decoration: underline;
		text-decoration-style: dashed;
		text-underline-offset: 4px;
		color: var(--text-secondary);
	}
	.breadcrumb a:hover {
		color: var(--accent-color);
	}
	.page-title-section {
		margin-bottom: 2rem;
	}
	.page-title-section h1 {
		margin-bottom: 1rem;
	}
	.search-container input {
		width: 100%;
		padding: 0.75rem 1rem;
		font-size: 1rem;
		border: 1px solid var(--border-color);
		border-radius: 8px;
		background-color: var(--bg-color);
		color: var(--text-primary);
		box-sizing: border-box;
		transition: border-color 0.2s ease;
	}
	.search-container input:focus {
		outline: none;
		border-color: var(--accent-color);
	}
	ol, ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
</style>

<script define:vars={{ posts }}>
	// Pass the posts collection to the client-side script
	const searchInput = document.getElementById('search-input');
	const resultsList = document.getElementById('results-list');
	const noResultsMessage = document.getElementById('no-results');

	function renderResults(filteredPosts) {
		resultsList.innerHTML = '';
		if (filteredPosts.length === 0) {
			noResultsMessage.style.display = 'block';
		} else {
			noResultsMessage.style.display = 'none';
			filteredPosts.forEach(post => {
				const li = document.createElement('li');
				li.className = 'post-list-item';
				
				// Format date strictly avoiding external libraries on client
				const dateObj = new Date(post.data.pubDate);
				const dateStr = dateObj.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });

				li.innerHTML = `
					<a href="/blog/${post.id}/" class="post-title">${post.data.title}</a>
					<div class="post-date">
						<svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
							<line x1="16" y1="2" x2="16" y2="6"></line>
							<line x1="8" y1="2" x2="8" y2="6"></line>
							<line x1="3" y1="10" x2="21" y2="10"></line>
						</svg>
						<time>${dateStr}</time>
					</div>
					<p>${post.data.description || ''}</p>
				`;
				resultsList.appendChild(li);
			});
		}
	}

	searchInput?.addEventListener('input', (e) => {
		const query = e.target.value.toLowerCase();
		if (!query) {
			resultsList.innerHTML = '';
			noResultsMessage.style.display = 'none';
			return;
		}

		const filtered = posts.filter(post => {
			const text = (post.data.title + ' ' + (post.data.description || '')).toLowerCase();
			return text.includes(query);
		});
		
		renderResults(filtered);
	});
</script>
